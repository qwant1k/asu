DB_HOST=db
DB_PORT=5432
POSTGRES_HOST_PORT=5432

# Redis / Celery
REDIS_URL=redis://redis:6379/0
REDIS_HOST_PORT=6379

# Email
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=asu@kfgd.kz
EMAIL_HOST_PASSWORD=
